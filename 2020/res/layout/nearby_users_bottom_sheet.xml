<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <com.roblox.client.components.RbxTextView
        android:textSize="18.0sp"
        android:textColor="@color/nearby_context_menu_text_color"
        android:gravity="center_vertical"
        android:id="@id/nearby_friend_profile_text_view"
        android:paddingLeft="20.0dip"
        android:paddingTop="15.0dip"
        android:paddingBottom="15.0dip"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:text="@string/Features_Nearby_Label_ViewProfile"
        android:drawableLeft="@drawable/nearby_context_menu_icon_profile"
        android:drawablePadding="20.0dip"
        android:drawableStart="@drawable/nearby_context_menu_icon_profile"
        android:paddingStart="20.0dip" />
    <com.roblox.client.components.RbxTextView
        android:textSize="18.0sp"
        android:textColor="@color/nearby_context_menu_text_color"
        android:gravity="center_vertical"
        android:id="@id/nearby_friend_cancel_text_view"
        android:paddingLeft="20.0dip"
        android:paddingTop="15.0dip"
        android:paddingBottom="15.0dip"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:text="@string/CommonUI_Controls_Action_Cancel"
        android:drawableLeft="@drawable/nearby_context_menu_icon_close"
        android:drawablePadding="20.0dip"
        android:drawableStart="@drawable/nearby_context_menu_icon_close"
        android:paddingStart="20.0dip" />
</LinearLayout>