        <receiver
            android:name="com.roblox.client.pushnotification.notificationreceivers.ChatMessageNotificationReceiver" />
        <receiver
            android:name="com.roblox.client.pushnotification.notificationreceivers.PrivateMessageReceivedNotificationReceiver" />
