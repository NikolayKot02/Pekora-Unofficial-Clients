<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    n1:id="@id/more_square_click_frame"
    n1:background="@drawable/more_page_item_selector"
    n1:layout_width="fill_parent"
    n1:layout_height="wrap_content"
    xmlns:n1="http://schemas.android.com/apk/res/android">
    <LinearLayout
        n1:gravity="center_vertical"
        n1:layout_gravity="left"
        n1:orientation="horizontal"
        n1:paddingTop="10.0dip"
        n1:paddingBottom="10.0dip"
        n1:layout_width="wrap_content"
        n1:layout_height="wrap_content">
        <View
            n1:layout_width="0.0dip"
            n1:layout_height="25.0dip" />
        <ImageView
            n1:id="@id/imageview_more_square"
            n1:layout_width="25.0dip"
            n1:layout_height="25.0dip"
            n1:layout_marginLeft="20.0dip"
            n1:scaleType="fitCenter" />
        <TextView
            n1:textSize="14.0sp"
            n1:textColor="@color/black"
            n1:gravity="center_horizontal"
            n1:id="@id/textview_more_square"
            n1:layout_width="wrap_content"
            n1:layout_height="wrap_content"
            n1:layout_marginLeft="20.0dip"
            style="@style/Theme.Roblox.StandardFontRegular" />
    </LinearLayout>
    <TextView
        n1:textSize="10.0sp"
        n1:textColor="@color/white"
        n1:gravity="center"
        n1:layout_gravity="center|right"
        n1:id="@id/textview_more_square_notification"
        n1:background="@drawable/circle_shape_red"
        n1:visibility="gone"
        n1:layout_width="wrap_content"
        n1:layout_height="wrap_content"
        n1:layout_marginRight="20.0dip"
        n1:minWidth="20.0dip"
        n1:minHeight="20.0dip" />
</FrameLayout>