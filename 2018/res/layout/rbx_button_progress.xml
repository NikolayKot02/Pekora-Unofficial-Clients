<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    n1:layout_width="fill_parent"
    n1:layout_height="fill_parent"
    xmlns:n1="http://schemas.android.com/apk/res/android">
    <com.roblox.client.components.RbxButton
        n1:id="@id/rbxProgressBtnRbxBtn"
        n1:background="@android:color/transparent"
        n1:layout_width="fill_parent"
        n1:layout_height="fill_parent" />
    <LinearLayout
        n1:orientation="vertical"
        n1:id="@id/rbxProgressBtnProgressContainer"
        n1:paddingLeft="@dimen/btnFlatStdPaddingLeftRight"
        n1:paddingTop="@dimen/btnFlatStdPaddingTopBtm"
        n1:paddingRight="@dimen/btnFlatStdPaddingLeftRight"
        n1:paddingBottom="@dimen/btnFlatStdPaddingTopBtm"
        n1:layout_width="fill_parent"
        n1:layout_height="fill_parent">
        <LinearLayout
            n1:layout_gravity="center_horizontal"
            n1:orientation="horizontal"
            n1:layout_width="wrap_content"
            n1:layout_height="fill_parent">
            <ProgressBar
                n1:layout_gravity="center_horizontal"
                n1:id="@id/rbxProgressBtnProgressBar"
                n1:layout_width="0.0dip"
                n1:layout_height="fill_parent"
                n1:indeterminateDrawable="@drawable/rbx_bg_progress_btn_spinner"
                n1:layout_weight="1.0"
                style="@android:style/Widget.ProgressBar.Small" />
            <com.roblox.client.components.RbxTextView
                n1:gravity="center_vertical"
                n1:layout_gravity="center"
                n1:id="@id/rbxProgressBtnProgressText"
                n1:layout_width="0.0dip"
                n1:layout_height="fill_parent"
                n1:layout_marginLeft="5.0dip"
                n1:singleLine="false"
                n1:layout_weight="10.0" />
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>