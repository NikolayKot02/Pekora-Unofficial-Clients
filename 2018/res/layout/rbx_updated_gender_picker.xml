<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    n1:orientation="vertical"
    n1:layout_width="fill_parent"
    n1:layout_height="fill_parent"
    xmlns:n1="http://schemas.android.com/apk/res/android">
    <LinearLayout
        n1:orientation="horizontal"
        n1:id="@id/rbxGenderContainer"
        n1:background="@drawable/rbx_bg_gender_full"
        n1:layout_width="wrap_content"
        n1:layout_height="0.0dip"
        n1:layout_weight="55.0">
        <RelativeLayout
            n1:layout_width="0.0dip"
            n1:layout_height="fill_parent"
            n1:layout_weight="4.0">
            <LinearLayout
                n1:layout_width="wrap_content"
                n1:layout_height="wrap_content"
                n1:layout_centerInParent="true">
                <ImageView
                    n1:id="@id/rbxGenderBtnMaleBg"
                    n1:layout_width="25.0dip"
                    n1:layout_height="25.0dip"
                    n1:src="@drawable/icon_male" />
                <TextView
                    n1:textSize="23.0sp"
                    n1:textColor="@color/RbxGray4"
                    n1:id="@id/rbxGenderBtnMaleTextView"
                    n1:layout_width="wrap_content"
                    n1:layout_height="wrap_content"
                    n1:text="@string/Authentication_SignUp_Label_Male" />
            </LinearLayout>
            <com.roblox.client.components.RbxButton
                n1:id="@id/rbxGenderBtnMale"
                n1:layout_width="fill_parent"
                n1:layout_height="fill_parent"
                n1:contentDescription="@string/Authentication_SignUp_Description_GenderPickerMaleContentDesc"
                style="@style/Theme.Roblox.Button.Gender.Male" />
        </RelativeLayout>
        <RelativeLayout
            n1:layout_width="0.0dip"
            n1:layout_height="fill_parent"
            n1:layout_weight="4.0">
            <View
                n1:background="@color/RbxGray4"
                n1:layout_width="1.0dip"
                n1:layout_height="fill_parent" />
            <LinearLayout
                n1:layout_width="wrap_content"
                n1:layout_height="wrap_content"
                n1:layout_centerInParent="true">
                <ImageView
                    n1:id="@id/rbxGenderBtnFemaleBg"
                    n1:layout_width="25.0dip"
                    n1:layout_height="25.0dip"
                    n1:src="@drawable/icon_female" />
                <TextView
                    n1:textSize="23.0sp"
                    n1:textColor="@color/RbxGray4"
                    n1:id="@id/rbxGenderBtnFemaleTextView"
                    n1:layout_width="wrap_content"
                    n1:layout_height="wrap_content"
                    n1:text="@string/Authentication_SignUp_Label_Female" />
            </LinearLayout>
            <com.roblox.client.components.RbxButton
                n1:id="@id/rbxGenderBtnFemale"
                n1:layout_width="fill_parent"
                n1:layout_height="fill_parent"
                n1:contentDescription="@string/Authentication_SignUp_Description_GenderPickerFemaleContentDesc"
                style="@style/Theme.Roblox.Button.Gender.Female" />
        </RelativeLayout>
    </LinearLayout>
    <LinearLayout
        n1:gravity="center_vertical"
        n1:orientation="horizontal"
        n1:layout_width="fill_parent"
        n1:layout_height="0.0dip"
        n1:layout_weight="25.0">
        <com.roblox.client.components.RbxTextView
            n1:textAppearance="?android:textAppearanceSmall"
            n1:textSize="@dimen/rbxEditTextHint"
            n1:textColor="@color/RbxRed2"
            n1:id="@id/rbxGenderBottomText"
            n1:background="@android:color/transparent"
            n1:visibility="invisible"
            n1:layout_width="wrap_content"
            n1:layout_height="wrap_content"
            n1:layout_marginLeft="2.0dip"
            n1:text="@string/Authentication_SignUp_Label_GenderRequired" />
    </LinearLayout>
</LinearLayout>