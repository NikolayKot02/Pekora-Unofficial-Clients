<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    n1:paddingLeft="12.0dip"
    n1:paddingTop="12.0dip"
    n1:paddingBottom="12.0dip"
    n1:layout_width="fill_parent"
    n1:layout_height="fill_parent"
    xmlns:n1="http://schemas.android.com/apk/res/android">
    <FrameLayout
        n1:id="@id/contact_thumbnail_layout"
        n1:background="@drawable/contact_status_ring"
        n1:padding="1.0dip"
        n1:layout_width="wrap_content"
        n1:layout_height="wrap_content"
        n1:layout_alignParentLeft="true"
        n1:layout_centerVertical="true">
        <ImageView
            n1:id="@id/contact_thumbnail"
            n1:layout_width="@dimen/chatConversationViewThumbnailSize"
            n1:layout_height="@dimen/chatConversationViewThumbnailSize"
            n1:src="@drawable/ic_avatar_placement" />
    </FrameLayout>
    <ImageView
        n1:id="@id/contact_thumbnail_checked"
        n1:background="@drawable/circle_shape_green"
        n1:padding="8.0dip"
        n1:visibility="gone"
        n1:layout_width="wrap_content"
        n1:layout_height="wrap_content"
        n1:src="@drawable/icon_check"
        n1:layout_alignLeft="@id/contact_thumbnail_layout"
        n1:layout_alignTop="@id/contact_thumbnail_layout"
        n1:layout_alignRight="@id/contact_thumbnail_layout"
        n1:layout_alignBottom="@id/contact_thumbnail_layout" />
    <View
        n1:id="@id/online_status_ring"
        n1:background="@drawable/circle_shape_white"
        n1:visibility="visible"
        n1:layout_width="20.0dip"
        n1:layout_height="20.0dip"
        n1:layout_alignRight="@id/contact_thumbnail_layout"
        n1:layout_alignBottom="@id/contact_thumbnail_layout" />
    <View
        n1:id="@id/online_status"
        n1:background="@drawable/circle_shape_green"
        n1:visibility="visible"
        n1:layout_width="16.0dip"
        n1:layout_height="16.0dip"
        n1:layout_margin="2.0dip"
        n1:layout_alignRight="@id/contact_thumbnail_layout"
        n1:layout_alignBottom="@id/contact_thumbnail_layout" />
    <ImageView
        n1:id="@id/contact_remove"
        n1:padding="12.0dip"
        n1:visibility="gone"
        n1:layout_width="48.0dip"
        n1:layout_height="48.0dip"
        n1:src="@drawable/icon_remove_selector"
        n1:layout_alignParentRight="true"
        n1:layout_centerVertical="true" />
    <ImageView
        n1:id="@id/contact_report"
        n1:padding="12.0dip"
        n1:visibility="visible"
        n1:layout_width="48.0dip"
        n1:layout_height="48.0dip"
        n1:src="@drawable/icon_flag_selector"
        n1:layout_toLeftOf="@id/contact_remove"
        n1:layout_centerVertical="true"
        n1:layout_alignWithParentIfMissing="true" />
    <LinearLayout
        n1:orientation="vertical"
        n1:layout_width="wrap_content"
        n1:layout_height="wrap_content"
        n1:layout_marginLeft="15.0dip"
        n1:layout_toLeftOf="@id/contact_report"
        n1:layout_toRightOf="@id/contact_thumbnail_layout"
        n1:layout_centerVertical="true">
        <com.roblox.client.components.RbxTextView
            n1:textSize="18.0sp"
            n1:textColor="@color/chatPrimary"
            n1:ellipsize="end"
            n1:id="@id/contact_name"
            n1:layout_width="wrap_content"
            n1:layout_height="wrap_content"
            n1:maxLines="1"
            style="@style/Theme.Roblox.StandardFontRegular" />
        <com.roblox.client.components.RbxTextView
            n1:textSize="16.0sp"
            n1:textColor="@color/chatSubText"
            n1:ellipsize="end"
            n1:id="@id/contact_subtext"
            n1:layout_width="wrap_content"
            n1:layout_height="wrap_content"
            n1:layout_marginTop="3.0dip"
            n1:text=""
            n1:maxLines="1"
            style="@style/Theme.Roblox.StandardFontRegular" />
    </LinearLayout>
</RelativeLayout>