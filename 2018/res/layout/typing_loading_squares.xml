<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    n1:layout_width="wrap_content"
    n1:layout_height="fill_parent"
    xmlns:n1="http://schemas.android.com/apk/res/android">
    <FrameLayout
        n1:layout_width="@dimen/typingProgressDotExpandSize"
        n1:layout_height="@dimen/typingProgressDotExpandSize">
        <View
            n1:layout_gravity="center"
            n1:id="@id/loading_squares_1"
            n1:background="@drawable/circle_shape_darkgray"
            n1:layout_width="@dimen/typingProgressDotSize"
            n1:layout_height="@dimen/typingProgressDotSize" />
    </FrameLayout>
    <FrameLayout
        n1:layout_width="@dimen/typingProgressDotExpandSize"
        n1:layout_height="@dimen/typingProgressDotExpandSize"
        n1:layout_marginLeft="10.0dip">
        <View
            n1:layout_gravity="center"
            n1:id="@id/loading_squares_2"
            n1:background="@drawable/circle_shape_darkgray"
            n1:layout_width="@dimen/typingProgressDotSize"
            n1:layout_height="@dimen/typingProgressDotSize" />
    </FrameLayout>
    <FrameLayout
        n1:layout_width="@dimen/typingProgressDotExpandSize"
        n1:layout_height="@dimen/typingProgressDotExpandSize"
        n1:layout_marginLeft="20.0dip">
        <View
            n1:layout_gravity="center"
            n1:id="@id/loading_squares_3"
            n1:background="@drawable/circle_shape_darkgray"
            n1:layout_width="@dimen/typingProgressDotSize"
            n1:layout_height="@dimen/typingProgressDotSize" />
    </FrameLayout>
</RelativeLayout>