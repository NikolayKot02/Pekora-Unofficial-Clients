<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    n1:gravity="bottom"
    n1:orientation="horizontal"
    n1:layout_width="wrap_content"
    n1:layout_height="wrap_content"
    xmlns:n1="http://schemas.android.com/apk/res/android">
    <TextView
        n1:textColor="#ffb8b8b8"
        n1:layout_width="wrap_content"
        n1:layout_height="wrap_content"
        n1:layout_marginRight="4.0dip"
        n1:text="@string/CommonUI_Messages_Label_Loading"
        n1:layout_marginEnd="4.0dip" />
    <ImageView
        n1:id="@id/dotImage1"
        n1:paddingBottom="2.0dip"
        n1:layout_width="wrap_content"
        n1:layout_height="wrap_content"
        n1:layout_marginRight="4.0dip"
        n1:src="@drawable/progress_dot"
        n1:contentDescription="@string/CommonUI_ContentDescription_Loading_Dot"
        n1:layout_marginEnd="4.0dip" />
    <ImageView
        n1:id="@id/dotImage2"
        n1:paddingBottom="2.0dip"
        n1:layout_width="wrap_content"
        n1:layout_height="wrap_content"
        n1:layout_marginRight="4.0dip"
        n1:src="@drawable/progress_dot"
        n1:contentDescription="@string/CommonUI_ContentDescription_Loading_Dot"
        n1:layout_marginEnd="4.0dip" />
    <ImageView
        n1:id="@id/dotImage3"
        n1:paddingBottom="2.0dip"
        n1:layout_width="wrap_content"
        n1:layout_height="wrap_content"
        n1:layout_marginRight="4.0dip"
        n1:src="@drawable/progress_dot"
        n1:contentDescription="@string/CommonUI_ContentDescription_Loading_Dot"
        n1:layout_marginEnd="4.0dip" />
</LinearLayout>