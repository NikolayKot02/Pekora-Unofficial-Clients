<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    n1:background="@color/RbxGray5"
    n1:paddingLeft="@dimen/morePageListPaddingLeft"
    n1:paddingRight="@dimen/morePageListPaddingRight"
    n1:layout_width="fill_parent"
    n1:layout_height="wrap_content"
    xmlns:n1="http://schemas.android.com/apk/res/android">
    <FrameLayout
        n1:layout_width="fill_parent"
        n1:layout_height="30.0dip">
        <View
            n1:layout_gravity="top"
            n1:id="@id/top_divider"
            n1:background="@color/chatBackground"
            n1:layout_width="fill_parent"
            n1:layout_height="1.0dip" />
        <View
            n1:layout_gravity="bottom"
            n1:id="@id/bottom_divider"
            n1:background="@color/chatBackground"
            n1:layout_width="fill_parent"
            n1:layout_height="1.0dip" />
    </FrameLayout>
</FrameLayout>